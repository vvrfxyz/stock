# .env.example
# Rename this file to .env and fill in your database connection details.
# Example for PostgreSQL:
DATABASE_URL="postgresql://user:password@host:port/database"

# PostgreSQL runs from docker-compose.yml by default (required: POSTGRES_PASSWORD).
POSTGRES_DB="stock"
POSTGRES_USER="postgres"
POSTGRES_PASSWORD=""
POSTGRES_PORT=5432
# 默认 compose 绑定 0.0.0.0；本机部署建议改为 127.0.0.1 避免对外暴露。
POSTGRES_BIND=127.0.0.1

# Massive API keys are loaded from the project-root file `activation_value.txt`
# Put one key per line in that file; blank lines and `#` comments are ignored

# SEC EDGAR fair-use policy requires a self-identifying User-Agent.
# Required by sync_sec_identifiers / update_sec_filings.
SEC_USER_AGENT="stock-pipeline your-email@example.com"

# One-off database migration tool (scripts/migrate_database.py)
OLD_DATABASE_URL="postgresql://user:password@host:port/old_database"
NEW_DATABASE_URL="postgresql://user:password@host:port/new_database"
