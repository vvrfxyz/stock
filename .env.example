# .env.example
# Rename this file to .env and fill in your database connection details.
# Example for PostgreSQL:
DATABASE_URL="postgresql://user:password@host:port/database"

# PostgreSQL runs from docker-compose.yml by default (required: POSTGRES_PASSWORD).
POSTGRES_DB="stock"
POSTGRES_USER="postgres"
POSTGRES_PASSWORD=""
POSTGRES_PORT=5432
# 数据库端口只绑定 loopback；远程访问统一走 SSH 隧道。
POSTGRES_BIND=127.0.0.1

# ClickHouse runs from docker-compose.yml and requires password authentication.
CLICKHOUSE_URL="http://127.0.0.1:8123"
CLICKHOUSE_DATABASE="stock"
CLICKHOUSE_USER="default"
CLICKHOUSE_PASSWORD=""
# Must be the lowercase SHA-256 hex digest of CLICKHOUSE_PASSWORD.
# Generate with: printf '%s' 'your-password' | shasum -a 256
CLICKHOUSE_PASSWORD_SHA256=""
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_BIND=127.0.0.1

# Massive API keys are loaded from the project-root file `activation_value.txt`
# Put one key per line in that file; blank lines and `#` comments are ignored

# SEC EDGAR fair-use policy requires a self-identifying User-Agent.
# Required by sync_sec_identifiers / update_sec_filings.
SEC_USER_AGENT="stock-pipeline your-email@example.com"

# OpenFIGI mapping API key (optional, for sync_openfigi_identifiers).
# 无 key 走匿名限额（10 jobs/请求、25 请求/分钟）也可用；
# 免费注册 key 后提速到 100 jobs/请求、25 请求/6 秒：https://www.openfigi.com/api
# OPENFIGI_API_KEY=""

# One-off database migration tool (scripts/migrate_database.py)
OLD_DATABASE_URL="postgresql://user:password@host:port/old_database"
NEW_DATABASE_URL="postgresql://user:password@host:port/new_database"
