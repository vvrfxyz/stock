# .env.example
# Rename this file to .env and fill in your database connection details.
# Example for PostgreSQL:
DATABASE_URL="postgresql://user:password@host:port/database"

# Massive (comma-separated keys; current primary source for US stocks)
MASSIVE_API_KEYS="YOUR_MASSIVE_KEY_1,YOUR_MASSIVE_KEY_2"

# Backward compatibility: legacy scripts still accept POLYGON_API_KEYS if MASSIVE_API_KEYS is absent
POLYGON_API_KEYS="YOUR_LEGACY_KEY_1,YOUR_LEGACY_KEY_2"

# One-off database migration tool (scripts/migrate_database.py)
OLD_DATABASE_URL="postgresql://user:password@host:port/old_database"
NEW_DATABASE_URL="postgresql://user:password@host:port/new_database"
