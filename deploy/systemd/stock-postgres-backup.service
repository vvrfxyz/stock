[Unit]
Description=Stock PostgreSQL nightly backup
Wants=docker.service
After=docker.service
OnFailure=stock-notify-failure@%n.service

[Service]
Type=oneshot
User=wenruifeng
Group=wenruifeng
WorkingDirectory=/home/wenruifeng/projects/stock
Environment=STOCK_REPO_DIR=/home/wenruifeng/projects/stock
ExecStart=/home/wenruifeng/projects/stock/scripts/backup_postgres.sh
TimeoutStartSec=2h
