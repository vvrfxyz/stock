[Unit]
Description=Stock data scheduled update
Wants=network-online.target docker.service
After=network-online.target docker.service

[Service]
Type=oneshot
User=wenruifeng
Group=wenruifeng
WorkingDirectory=/home/wenruifeng/projects/stock
Environment=STOCK_REPO_DIR=/home/wenruifeng/projects/stock
Environment=STOCK_MARKET=US
ExecStart=/home/wenruifeng/projects/stock/scripts/run_daily_cron.sh
TimeoutStartSec=12h
